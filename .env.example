# ===== WINLERR ENVIRONMENT VARIABLES =====

# Supabase — get these from your Supabase project dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role Key — server-side only, never expose in frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=Winlerr <hello@winlerr.com>

# Admin notification email — receives prototype request alerts
ADMIN_NOTIFICATION_EMAIL=admin@winlerr.com

# Site URL — used in email templates for links back to the site
SITE_URL=https://winlerr.com

# Resend Audience ID — optional, for contact management
# RESEND_AUDIENCE_ID=
